# Copy to .env and fill in to enable the optional AI enrichment feature.
# The static web app works fine without this — the AI button simply stays hidden.

# OpenAI API key. Required.
OPENAI_API_KEY=

# OpenAI-compatible endpoint base. Optional; defaults to https://api.openai.com/v1
# Point at a proxy (Azure OpenAI, LiteLLM, Cloudflare AI Gateway, …) that
# implements the Responses API + web_search tool if you don't want to hit
# OpenAI directly.
# OPENAI_API_BASE=https://api.openai.com/v1

# Model. Optional; defaults to gpt-5.4-mini.
# BAYES_MODEL=gpt-5.4-mini

# Provider id. Optional; only "openai" is implemented today.
# BAYES_PROVIDER=openai

# Port for the API server. Optional; defaults to 3001 (matches vite proxy).
# BAYES_PORT=3001
